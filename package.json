{
  "name": "@gahojin-inc/aws-lambda-mock-context",
  "version": "2026.4.0",
  "description": "AWS Lambda mock context object",
  "author": "GAHOJIN, Inc.",
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/gahojin/aws-lambda-mock-context.git"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "aws",
    "lambda",
    "mock"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "prepare": "biome migrate --write",
    "build": "rolldown -c",
    "prepublishOnly": "pnpm run build",
    "lint": "biome check --write .",
    "check": "tsgo",
    "check:packagejson": "attw --pack --profile esm-only .",
    "test": "vitest --watch",
    "test:unit": "vitest --passWithNoTests --run --coverage",
    "ncu": "mise run ncu"
  },
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.2",
    "@biomejs/biome": "2.4.10",
    "@types/aws-lambda": "8.10.161",
    "@types/node": "24.12.2",
    "@typescript/native-preview": "7.0.0-dev.20260324.1",
    "@vitest/coverage-v8": "4.1.3",
    "jest-extended": "7.0.0",
    "rolldown": "1.0.0-rc.13",
    "rolldown-plugin-dts": "0.23.2",
    "vite": "8.0.7",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.3"
  },
  "packageManager": "pnpm@10.33.0"
}
