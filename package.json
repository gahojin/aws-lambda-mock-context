{
  "name": "@gahojin-inc/aws-lambda-mock-context",
  "version": "2026.4.0",
  "description": "AWS Lambda mock context object",
  "author": "GAHOJIN, Inc.",
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/gahojin/aws-lambda-mock-context.git"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "aws",
    "lambda",
    "mock"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "prepare": "biome migrate --write",
    "build": "vite build",
    "prepublishOnly": "pnpm run build",
    "lint": "biome check --write .",
    "check": "tsc",
    "check:packagejson": "attw --pack --profile esm-only .",
    "test": "vitest --watch",
    "test:unit": "vitest --passWithNoTests --run --coverage",
    "ncu": "mise run ncu"
  },
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.2",
    "@biomejs/biome": "2.4.13",
    "@types/aws-lambda": "8.10.161",
    "@types/node": "24.12.2",
    "@vitest/coverage-v8": "4.1.5",
    "jest-extended": "7.0.0",
    "typescript": "6.0.3",
    "vite": "8.0.10",
    "vite-plugin-dts": "5.0.0",
    "vitest": "4.1.5"
  },
  "packageManager": "pnpm@10.33.2"
}
