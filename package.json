{
  "name": "@gahojin-inc/aws-lambda-mock-context",
  "version": "2026.5.1",
  "description": "AWS Lambda mock context object",
  "author": "GAHOJIN, Inc.",
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/gahojin/aws-lambda-mock-context.git"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "aws",
    "lambda",
    "mock"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "prepare": "biome migrate --write",
    "build": "vite build",
    "prepublishOnly": "pnpm run build",
    "lint": "biome check --write .",
    "check": "tsc",
    "test": "vitest --watch",
    "test:unit": "vitest --passWithNoTests --run --coverage",
    "ncu": "mise run ncu"
  },
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@types/aws-lambda": "catalog:",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "typescript": "catalog:",
    "unplugin-dts": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "packageManager": "pnpm@11.1.1"
}
